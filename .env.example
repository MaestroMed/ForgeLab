# FORGE/LAB environment configuration. Copy to .env and adjust.
# Every engine variable is read by forge_engine.core.config.Settings via the
# FORGE_ prefix (pydantic-settings).

# --- Debug / observability ---
# Enable FastAPI /docs + /redoc and widen CORS to common local dev ports.
# Leave unset (or =0) in production.
# FORGE_DEBUG=0

# --- Paths ---
# Where projects, the SQLite DB, and the temp workspace live.
# FORGE_LIBRARY_PATH=/home/you/FORGE_LIBRARY

# Additional import roots the API will accept as source_path (OS path-sep or
# comma separated). LIBRARY_PATH and $HOME are always allowed.
# FORGE_ALLOWED_IMPORT_ROOTS=/mnt/recordings:/mnt/obs

# --- Networking ---
# FORGE_HOST=127.0.0.1
# FORGE_PORT=7860
# CORS allowlist used when FORGE_DEBUG is off (JSON array).
# FORGE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Job queue ---
# Sequential by default for GPU/FFmpeg stability. Raise when the host has
# headroom (multi-GPU, CPU-only pipelines).
# FORGE_MAX_WORKERS=1

# --- GPU / ML ---
# FORGE_FORCE_CPU=0
# FORGE_WHISPER_MODEL=large-v3
# FORGE_WHISPER_DEVICE=cuda       # cuda | cpu
# FORGE_WHISPER_COMPUTE_TYPE=float16  # float16 | int8 | float32

# --- FFmpeg ---
# FORGE_FFMPEG_PATH=ffmpeg
# FORGE_FFPROBE_PATH=ffprobe
